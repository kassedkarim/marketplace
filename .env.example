# قاعدة البيانات (PostgreSQL) - غيّرها ببيانات اتصالك
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace"

# NextAuth - أي نص عشوائي طويل وسري، تقدر تولده بالأمر: openssl rand -base64 32
NEXTAUTH_SECRET="غيّر_ده_بنص_سري_عشوائي"
NEXTAUTH_URL="http://localhost:3000"

# تسجيل الدخول بجوجل - من https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# تسجيل الدخول بفيسبوك - من https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
